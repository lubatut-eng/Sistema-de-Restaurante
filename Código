def menu_funcionarios(restaurante):
    while True:
        print("\n--- GESTÃO DE FUNCIONÁRIOS ---")
        print("1. Cadastrar funcionário")
        print("2. Listar funcionários")
        print("3. Remover funcionário")
        print("0. Voltar")
        opcao = input("Escolha uma opção: ").strip()

        try:
            if opcao == "1":
                nome = ler_texto("Nome: ")
                cargo = ler_texto("Cargo: ")
                salario = ler_float("Salário: R$ ")
                func = restaurante.cadastrar_funcionario(nome, cargo, salario)
                print(f"Funcionário cadastrado com sucesso! {func}")

            elif opcao == "2":
                funcionarios = restaurante.listar_funcionarios()
                if not funcionarios:
                    print("Nenhum funcionário cadastrado.")
                else:
                    for f in funcionarios:
                        print(f)

            elif opcao == "3":
                id_func = ler_int("ID do funcionário a remover: ")
                restaurante.remover_funcionario(id_func)
                print("Funcionário removido com sucesso!")

            elif opcao == "0":
                break
            else:
                print("Opção inválida!")

        except RestauranteError as e:
            print(f"Erro: {e}")

        pausar()


