class RestauranteError(Exception):
    """Classe base para todos os erros do sistema do restaurante."""
    pass


class MesaOcupadaError(RestauranteError):
    """Lançada ao tentar ocupar uma mesa que já está em uso."""
    pass


class MesaNaoEncontradaError(RestauranteError):
    """Lançada quando uma mesa não é encontrada pelo número."""
    pass


class PratoNaoEncontradoError(RestauranteError):
    """Lançada quando um prato não é encontrado pelo ID."""
    pass


class FuncionarioNaoEncontradoError(RestauranteError):
    """Lançada quando um funcionário não é encontrado pelo ID."""
    pass


class PedidoNaoEncontradoError(RestauranteError):
    """Lançada quando um pedido não é encontrado pelo ID."""
    pass


class EntradaInvalidaError(RestauranteError):
    """Lançada quando o usuário fornece uma entrada inválida."""
    pass


# ============================================================
# CLASSES DO DOMÍNIO (POO)
# ============================================================

class Ingrediente:
    """Representa um ingrediente usado em um ou mais pratos."""

    def __init__(self, nome, quantidade_estoque, unidade="kg"):
        self.nome = nome
        self.quantidade_estoque = quantidade_estoque
        self.unidade = unidade

    def __str__(self):
        return f"{self.nome} ({self.quantidade_estoque}{self.unidade} em estoque)"


class Prato:
    """Representa um item do cardápio."""

    _proximo_id = 1  # atributo de classe: gera os IDs automaticamente

    def __init__(self, nome, preco, categoria, ingredientes=None):
        self.id = Prato._proximo_id
        Prato._proximo_id += 1
        self.nome = nome
        self.preco = preco
        self.categoria = categoria
        # lista de objetos Ingrediente associados a este prato
        self.ingredientes = ingredientes if ingredientes is not None else []

    def adicionar_ingrediente(self, ingrediente):
        self.ingredientes.append(ingrediente)

    def __str__(self):
        nomes_ingredientes = ", ".join(i.nome for i in self.ingredientes) or "Nenhum"
        return (f"#{self.id} | {self.nome:<22} | R$ {self.preco:>7.2f} | "
                f"{self.categoria:<14} | Ingredientes: {nomes_ingredientes}")


class Funcionario:
    """Representa um funcionário do restaurante."""

    _proximo_id = 1

    def __init__(self, nome, cargo, salario):
        self.id = Funcionario._proximo_id
        Funcionario._proximo_id += 1
        self.nome = nome
        self.cargo = cargo
        self.salario = salario

    def __str__(self):
        return f"#{self.id} | {self.nome:<22} | {self.cargo:<15} | R$ {self.salario:>9.2f}"


class Mesa:
    """Representa uma mesa do restaurante."""

    def __init__(self, numero, capacidade):
        self.numero = numero
        self.capacidade = capacidade
        self.ocupada = False

    def ocupar(self):
        if self.ocupada:
            raise MesaOcupadaError(f"A mesa {self.numero} já está ocupada.")
        self.ocupada = True

    def liberar(self):
        self.ocupada = False

    def __str__(self):
        status = "OCUPADA" if self.ocupada else "LIVRE"
        return f"Mesa {self.numero:<3} | Capacidade: {self.capacidade:<3} | Status: {status}"


class Pedido:
    """Representa um pedido feito em uma mesa."""

    _proximo_id = 1

    def __init__(self, mesa):
        self.id = Pedido._proximo_id
        Pedido._proximo_id += 1
        self.mesa = mesa
        self.itens = []      # lista de dicionários: {"prato": Prato, "quantidade": int}
        self.status = "Aberto"

    def adicionar_item(self, prato, quantidade=1):
        if quantidade <= 0:
            raise EntradaInvalidaError("A quantidade deve ser maior que zero.")
        self.itens.append({"prato": prato, "quantidade": quantidade})

    def calcular_total(self):
        return sum(item["prato"].preco * item["quantidade"] for item in self.itens)

    def fechar(self):
        self.status = "Fechado"
        self.mesa.liberar()

    def __str__(self):
        linhas = [f"Pedido #{self.id} | Mesa {self.mesa.numero} | Status: {self.status}"]
        if not self.itens:
            linhas.append("  (nenhum item adicionado)")
        for item in self.itens:
            subtotal = item["prato"].preco * item["quantidade"]
            linhas.append(f"  {item['quantidade']}x {item['prato'].nome:<20} R$ {subtotal:>8.2f}")
        linhas.append(f"  {'TOTAL:':<25}R$ {self.calcular_total():>8.2f}")
        return "\n".join(linhas)


# ============================================================
# CLASSE PRINCIPAL: RESTAURANTE
# ============================================================

class Restaurante:
    """
    Classe principal que agrega todas as outras entidades
    (funcionários, pratos, mesas e pedidos) e oferece os
    métodos de negócio do sistema.
    """

    def __init__(self, nome):
        self.nome = nome
        self.funcionarios = {}   # dict: {id: Funcionario}
        self.cardapio = {}       # dict: {id: Prato}
        self.mesas = {}          # dict: {numero: Mesa}
        self.pedidos = {}        # dict: {id: Pedido}

    # ---------------- FUNCIONÁRIOS ----------------
    def cadastrar_funcionario(self, nome, cargo, salario):
        funcionario = Funcionario(nome, cargo, salario)
        self.funcionarios[funcionario.id] = funcionario
        return funcionario

    def listar_funcionarios(self):
        return list(self.funcionarios.values())

    def remover_funcionario(self, id_funcionario):
        if id_funcionario not in self.funcionarios:
            raise FuncionarioNaoEncontradoError(f"Funcionário #{id_funcionario} não encontrado.")
        del self.funcionarios[id_funcionario]

    # ---------------- CARDÁPIO / PRATOS ----------------
    def cadastrar_prato(self, nome, preco, categoria, ingredientes=None):
        prato = Prato(nome, preco, categoria, ingredientes)
        self.cardapio[prato.id] = prato
        return prato

    def listar_cardapio(self):
        return list(self.cardapio.values())

    def buscar_prato(self, id_prato):
        if id_prato not in self.cardapio:
            raise PratoNaoEncontradoError(f"Prato #{id_prato} não encontrado.")
        return self.cardapio[id_prato]

    def remover_prato(self, id_prato):
        if id_prato not in self.cardapio:
            raise PratoNaoEncontradoError(f"Prato #{id_prato} não encontrado.")
        del self.cardapio[id_prato]

    # ---------------- MESAS ----------------
    def cadastrar_mesa(self, numero, capacidade):
        if numero in self.mesas:
            raise EntradaInvalidaError(f"Já existe uma mesa com o número {numero}.")
        mesa = Mesa(numero, capacidade)
        self.mesas[numero] = mesa
        return mesa

    def listar_mesas(self):
        return list(self.mesas.values())

    def buscar_mesa(self, numero):
        if numero not in self.mesas:
            raise MesaNaoEncontradaError(f"Mesa {numero} não encontrada.")
        return self.mesas[numero]

    # ---------------- PEDIDOS ----------------
    def abrir_pedido(self, numero_mesa):
        mesa = self.buscar_mesa(numero_mesa)
        mesa.ocupar()  # lança MesaOcupadaError se a mesa já estiver ocupada
        pedido = Pedido(mesa)
        self.pedidos[pedido.id] = pedido
        return pedido

    def buscar_pedido(self, id_pedido):
        if id_pedido not in self.pedidos:
            raise PedidoNaoEncontradoError(f"Pedido #{id_pedido} não encontrado.")
        return self.pedidos[id_pedido]

    def listar_pedidos(self, apenas_abertos=False):
        pedidos = list(self.pedidos.values())
        if apenas_abertos:
            pedidos = [p for p in pedidos if p.status == "Aberto"]
        return pedidos

    def fechar_pedido(self, id_pedido):
        pedido = self.buscar_pedido(id_pedido)
        pedido.fechar()
        return pedido

    def faturamento_total(self):
        return sum(p.calcular_total() for p in self.pedidos.values() if p.status == "Fechado")


# ============================================================
# FUNÇÕES AUXILIARES DE ENTRADA (com tratamento de erros)
# ============================================================

def ler_texto(mensagem):
    valor = input(mensagem).strip()
    if not valor:
        raise EntradaInvalidaError("O campo não pode ficar em branco.")
    return valor


def ler_float(mensagem):
    try:
        return float(input(mensagem).strip().replace(",", "."))
    except ValueError:
        raise EntradaInvalidaError("Valor numérico inválido. Use apenas números.")


def ler_int(mensagem):
    try:
        return int(input(mensagem).strip())
    except ValueError:
        raise EntradaInvalidaError("Valor inteiro inválido. Digite apenas números.")


def pausar():
    input("\nPressione ENTER para continuar...")


