    print(f"Total de funcionários: {len(restaurante.funcionarios)}")
    print(f"Total de pratos no cardápio: {len(restaurante.cardapio)}")
    print(f"Total de mesas: {len(restaurante.mesas)}")
    print(f"Pedidos abertos: {len(restaurante.listar_pedidos(apenas_abertos=True))}")
    print(f"Faturamento total (pedidos fechados): R$ {restaurante.faturamento_total():.2f}")
    pausar()


