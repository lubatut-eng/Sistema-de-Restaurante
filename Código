def menu_pedidos(restaurante):
    while True:
        print("\n--- GESTÃO DE PEDIDOS ---")
        print("1. Abrir novo pedido")
        print("2. Adicionar item a um pedido")
        print("3. Listar pedidos")
        print("4. Fechar pedido (gerar conta)")
        print("0. Voltar")
        opcao = input("Escolha uma opção: ").strip()

        try:
            if opcao == "1":
                numero_mesa = ler_int("Número da mesa: ")
                pedido = restaurante.abrir_pedido(numero_mesa)
                print(f"Pedido #{pedido.id} aberto na mesa {numero_mesa}.")

            elif opcao == "2":
                id_pedido = ler_int("ID do pedido: ")
                pedido = restaurante.buscar_pedido(id_pedido)

                print("\nCardápio disponível:")
                for prato in restaurante.listar_cardapio():
                    print(prato)

                id_prato = ler_int("\nID do prato a adicionar: ")
                prato = restaurante.buscar_prato(id_prato)
                quantidade = ler_int("Quantidade: ")
                pedido.adicionar_item(prato, quantidade)
                print(f"{quantidade}x {prato.nome} adicionado(s) ao pedido #{pedido.id}.")

            elif opcao == "3":
                resposta = input("Mostrar apenas pedidos abertos? (s/n): ").strip().lower()
                apenas_abertos = resposta == "s"
                pedidos = restaurante.listar_pedidos(apenas_abertos)
                if not pedidos:
                    print("Nenhum pedido encontrado.")
                else:
                    for p in pedidos:
                        print(p)
                        print("-" * 40)

            elif opcao == "4":
                id_pedido = ler_int("ID do pedido a fechar: ")
                pedido = restaurante.fechar_pedido(id_pedido)
                print("\nConta fechada:")
                print(pedido)

            elif opcao == "0":
                break
            else:
                print("Opção inválida!")

        except RestauranteError as e:
            print(f"Erro: {e}")

        pausar()


